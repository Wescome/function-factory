{
  "name": "function-factory",
  "version": "0.0.1",
  "private": true,
  "description": "An upstream-to-downstream compiler for trustworthy executable Functions.",
  "author": "Wislet J. Celestin <wes@koales.ai>",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "compile": "pnpm --filter @factory/compiler run compile",
    "delta:test": "pnpm --filter @factory/capability-delta run test",
    "delta:typecheck": "pnpm --filter @factory/capability-delta run typecheck",
    "prd-authoring:test": "pnpm --filter @factory/prd-authoring run test",
    "prd-authoring:typecheck": "pnpm --filter @factory/prd-authoring run typecheck",
    "recursion-governance:test": "pnpm --filter @factory/recursion-governance run test",
    "recursion-governance:typecheck": "pnpm --filter @factory/recursion-governance run typecheck",
    "architecture-candidates:test": "pnpm --filter @factory/architecture-candidates run test",
    "architecture-candidates:typecheck": "pnpm --filter @factory/architecture-candidates run typecheck",
    "candidate-selection:test": "pnpm --filter @factory/candidate-selection run test",
    "candidate-selection:typecheck": "pnpm --filter @factory/candidate-selection run typecheck",
    "runtime-admission:test": "pnpm --filter @factory/runtime-admission run test",
    "runtime-admission:typecheck": "pnpm --filter @factory/runtime-admission run typecheck",
    "execution-lifecycle:test": "pnpm --filter @factory/execution-lifecycle run test",
    "execution-lifecycle:typecheck": "pnpm --filter @factory/execution-lifecycle run typecheck",
    "controlled-effectors:test": "pnpm --filter @factory/controlled-effectors run test",
    "controlled-effectors:typecheck": "pnpm --filter @factory/controlled-effectors run typecheck",
    "effector-realization:test": "pnpm --filter @factory/effector-realization run test",
    "effector-realization:typecheck": "pnpm --filter @factory/effector-realization run typecheck",
    "observability-feedback:test": "pnpm --filter @factory/observability-feedback run test",
    "observability-feedback:typecheck": "pnpm --filter @factory/observability-feedback run typecheck",
    "signal-hygiene:test": "pnpm --filter @factory/signal-hygiene run test",
    "signal-hygiene:typecheck": "pnpm --filter @factory/signal-hygiene run typecheck",
    "adaptive-recalibration:test": "pnpm --filter @factory/adaptive-recalibration run test",
    "adaptive-recalibration:typecheck": "pnpm --filter @factory/adaptive-recalibration run typecheck",
    "selection-bias:test": "pnpm --filter @factory/selection-bias run test",
    "selection-bias:typecheck": "pnpm --filter @factory/selection-bias run typecheck",
    "meta-governance:test": "pnpm --filter @factory/meta-governance run test",
    "meta-governance:typecheck": "pnpm --filter @factory/meta-governance run typecheck",
    "policy-activation:test": "pnpm --filter @factory/policy-activation run test",
    "policy-activation:typecheck": "pnpm --filter @factory/policy-activation run typecheck",
    "autonomous-scheduler:test": "pnpm --filter @factory/autonomous-scheduler run test",
    "autonomous-scheduler:typecheck": "pnpm --filter @factory/autonomous-scheduler run typecheck",
    "dream": "tsx .agent/tools/dream.ts",
    "bootstrap": "tsx scripts/bootstrap.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "yaml": "^2.4.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": []
    }
  }
}
