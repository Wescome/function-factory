@prefix ff:    <https://koales.ai/ontology/function-factory#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sase:  <https://koales.ai/ontology/sase#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# ═══════════════════════════════════════════════════════════════════
# Function Factory Ontology — Complete Closed-World Model
#
# Version: 1.0.0
# Date: 2026-04-27
# Author: Koales.ai / Wislet J. Celestin
#
# This ontology defines EVERYTHING that exists in the Function Factory.
# Anything not in this ontology does not exist to Factory agents.
# Constraints encoded here make structural failures impossible.
# ═══════════════════════════════════════════════════════════════════

<https://koales.ai/ontology/function-factory> a owl:Ontology ;
    rdfs:label "Function Factory Closed-World Model" ;
    rdfs:comment """Complete world model for the Function Factory — a closed-loop
    compiler that converts environmental Signals into trustworthy executable
    Functions. Grounded in SASE (Hassan et al. 2025), the Factory whitepaper,
    and operational lessons from bootstrap deployment (2026-04-25/27).""" ;
    owl:versionInfo "1.0.0" .


# ═══════════════════════════════════════════════════════════════════
# DOMAIN 1: SIGNALS & ENVIRONMENT
# Everything that enters the Factory from outside
# ═══════════════════════════════════════════════════════════════════

ff:EnvironmentalInput a owl:Class ;
    rdfs:label "Environmental Input" ;
    rdfs:comment "Any observation from outside the Factory that may trigger action." .

ff:Signal a owl:Class ;
    rdfs:subClassOf ff:EnvironmentalInput ;
    rdfs:label "Signal" ;
    rdfs:comment "A typed observation from the environment. Origin point of all lineage chains." .

ff:SignalType a owl:Class ;
    owl:oneOf ( ff:MarketSignal ff:CustomerSignal ff:CompetitorSignal
                ff:RegulatorySignal ff:InternalSignal ff:MetaSignal ) .

ff:MarketSignal a ff:SignalType . ff:CustomerSignal a ff:SignalType .
ff:CompetitorSignal a ff:SignalType . ff:RegulatorySignal a ff:SignalType .
ff:InternalSignal a ff:SignalType . ff:MetaSignal a ff:SignalType .

ff:CIFeedbackSignal a owl:Class ;
    rdfs:subClassOf ff:Signal ;
    rdfs:comment "Signal generated by CI pipeline events (test failure, build error, deployment result)." .

ff:ObservabilitySignal a owl:Class ;
    rdfs:subClassOf ff:Signal ;
    rdfs:comment "Signal generated by runtime monitoring (drift detection, invariant violation, latency spike)." .

ff:ArchitectObservation a owl:Class ;
    rdfs:subClassOf ff:Signal ;
    rdfs:comment "Signal authored by the human architect identifying a gap, need, or opportunity." .


# ═══════════════════════════════════════════════════════════════════
# DOMAIN 2: SPECIFICATION CHAIN
# The full derivation path from Signal to executable WorkGraph
# ═══════════════════════════════════════════════════════════════════

ff:SpecificationArtifact a owl:Class ;
    rdfs:label "Specification Artifact" ;
    rdfs:comment "Any artifact in the Signal → WorkGraph derivation chain." .

ff:Pressure a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "Pressure (Forcing Function)" ;
    rdfs:comment "A named, prioritized force acting on the system derived from one or more Signals." .

ff:PressureCategory a owl:Class ;
    owl:oneOf ( ff:Growth ff:Retention ff:Reliability ff:Compliance
                ff:Risk ff:Efficiency ff:CompetitiveGap ff:Trust ) .

ff:BusinessCapability a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "Business Capability" ;
    rdfs:comment "A concrete system ability that addresses a Pressure." .

ff:FunctionProposal a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "Function Proposal" ;
    rdfs:comment "A concrete, implementable unit of work with a PRD skeleton." .

ff:FunctionType a owl:Class ;
    owl:oneOf ( ff:ExecutionFunction ff:ControlFunction
                ff:EvidenceFunction ff:IntegrationFunction ) .

ff:PRDDraft a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "PRD Draft" ;
    rdfs:comment "Product Requirements Document — the compiler's input." .

ff:RequirementAtom a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "Requirement Atom" ;
    rdfs:comment "Minimal, independently verifiable unit of a requirement." .

ff:AtomCategory a owl:Class ;
    owl:oneOf ( ff:UserStory ff:BusinessRule ff:Constraint
                ff:NFR ff:Integration ff:Acceptance ) .

ff:Contract a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "Contract" ;
    rdfs:comment "A typed interface or behavioral agreement between components." .

ff:ContractKind a owl:Class ;
    owl:oneOf ( ff:APIContract ff:SchemaContract
                ff:BehaviorContract ff:InvariantContract ) .

ff:Invariant a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "Invariant" ;
    rdfs:comment "A property that must always hold. Without a detector, it is a wish." .

ff:InvariantScope a owl:Class ;
    owl:oneOf ( ff:EntityScope ff:WorkflowScope ff:SystemScope ) .

ff:DetectorSpec a owl:Class ;
    rdfs:label "Detector Specification" ;
    rdfs:comment "How to check an Invariant. Required fields: evidence_sources, direct_rules, warning_rules, regression_policy, incident_tags." .

ff:ValidationSpec a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "Validation Specification" ;
    rdfs:comment "A test specification derived from atoms, contracts, and invariants." .

ff:ValidationKind a owl:Class ;
    owl:oneOf ( ff:CompileCheck ff:LintCheck ff:UnitTest ff:IntegrationTest
                ff:ScenarioTest ff:PropertyTest ff:SecurityTest ff:PerformanceTest ) .

ff:Dependency a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "Dependency" ;
    rdfs:comment "A directional relationship between specification elements." .

ff:DependencyType a owl:Class ;
    owl:oneOf ( ff:Blocks ff:Constrains ff:Implements ff:Validates ff:Informs ) .

ff:WorkGraph a owl:Class ;
    rdfs:subClassOf ff:SpecificationArtifact ;
    rdfs:label "WorkGraph" ;
    rdfs:comment "The compiled, executable specification. Assembly of atoms as nodes and dependencies as edges." .

ff:WorkGraphNode a owl:Class ;
    rdfs:comment "A node in a WorkGraph — typed by its implementing atom." .

ff:NodeType a owl:Class ;
    owl:oneOf ( ff:InterfaceNode ff:ExecutionNode ff:ControlNode ff:EvidenceNode ) .


# ═══════════════════════════════════════════════════════════════════
# DOMAIN 3: GOVERNANCE & TRUST
# Everything that constrains, validates, and assures
# ═══════════════════════════════════════════════════════════════════

ff:GovernanceArtifact a owl:Class ;
    rdfs:label "Governance Artifact" ;
    rdfs:comment "Any artifact that constrains, validates, or assures Factory output." .

ff:Gate a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:label "Gate" ;
    rdfs:comment "A fail-closed validation checkpoint. Three gates, all required." .

ff:Gate1 a ff:Gate ;
    rdfs:label "Gate 1 — Compile Coverage" ;
    rdfs:comment "Structural validation: atom coverage, invariant coverage, validation coverage, dependency closure." .

ff:Gate2 a ff:Gate ;
    rdfs:label "Gate 2 — Simulation Coverage" ;
    rdfs:comment "Behavioral validation: scenario coverage, invariant exercise, validation pass rate." .

ff:Gate3 a ff:Gate ;
    rdfs:label "Gate 3 — Assurance" ;
    rdfs:comment "Continuous validation: detector freshness, evidence source liveness, audit pipeline integrity." .

ff:CoverageReport a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:label "Coverage Report" ;
    rdfs:comment "The evidence artifact emitted by a Gate. Lineage-preserving." .

ff:CoverageCheck a owl:Class ;
    rdfs:comment "A single check within a Coverage Report." .

ff:TrustComposite a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:label "Trust Composite" ;
    rdfs:comment "Computed trust score for a Function based on Gate results and invariant health." .

ff:Trajectory a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:label "Trajectory" ;
    rdfs:comment "A detected drift pattern across time — triggers ProblemFrames." .

ff:ProblemFrame a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:label "Problem Frame" ;
    rdfs:comment "A structured problem statement derived from a Trajectory." .

ff:Incident a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:label "Incident" ;
    rdfs:comment "A detected violation of one or more Invariants." .

ff:IncidentSeverity a owl:Class ;
    owl:oneOf ( ff:Sev1 ff:Sev2 ff:Sev3 ff:Sev4 ) .

ff:MentorScript a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:label "MentorScript Rule" ;
    rdfs:comment "A typed, testable, version-controlled operational rule. Behavioral constraint for agents." .

ff:MentorSource a owl:Class ;
    owl:oneOf ( ff:ArchitectAuthored ff:InferredFromCorrection ff:CrystallizedFromExecution ) .

ff:PolicyStressReport a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:comment "Detects when a policy is being repeatedly stressed or circumvented." .

ff:GovernanceProposal a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:comment "A proposed change to a governance policy." .

ff:GovernanceDecision a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:comment "An approved or rejected governance proposal." .

ff:PolicySuccessorNote a owl:Class ;
    rdfs:subClassOf ff:GovernanceArtifact ;
    rdfs:comment "Records the lineage when one policy supersedes another." .


# ═══════════════════════════════════════════════════════════════════
# DOMAIN 4: EXECUTION & SYNTHESIS
# Everything that produces code
# ═══════════════════════════════════════════════════════════════════

ff:ExecutionArtifact a owl:Class ;
    rdfs:label "Execution Artifact" ;
    rdfs:comment "Any artifact produced during Stage 6 synthesis." .

ff:BriefingScript a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:label "BriefingScript" ;
    rdfs:comment """SASE §5.1 — the mission brief. NOT a prompt. A structured, version-controlled
    specification of intent with: goal, successCriteria, architecturalContext, strategicAdvice,
    knownGotchas, validationLoop. Produced by the Architect Agent with full codebase context.""" .

ff:Plan a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:label "Plan" ;
    rdfs:comment "Implementation plan decomposing a WorkGraph into actionable steps." .

ff:CodeArtifact a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:label "Code Artifact" ;
    rdfs:comment "Files produced by the Coder role — paths, contents, actions (create/modify/delete)." .

ff:CritiqueReport a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:label "Critique Report" ;
    rdfs:comment "Code review output from the Critic role — issues, mentor rule compliance, assessment." .

ff:TestReport a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:label "Test Report" ;
    rdfs:comment "Test execution results — pass/fail, coverage, failures." .

ff:Verdict a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:label "Verdict" ;
    rdfs:comment "Final synthesis decision from the Verifier role." .

ff:VerdictDecision a owl:Class ;
    owl:oneOf ( ff:Pass ff:Patch ff:Resample ff:Interrupt ff:Fail ) .

ff:SynthesisSession a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:comment "A complete synthesis run — all role outputs, token usage, repair count." .

ff:RepairCycle a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:comment "A single iteration of the patch/resample repair loop." .

ff:SandboxSession a owl:Class ;
    rdfs:subClassOf ff:ExecutionArtifact ;
    rdfs:comment "A real filesystem execution in a CF Container — git clone, pnpm install, agent loop, test run." .


# ═══════════════════════════════════════════════════════════════════
# DOMAIN 5: HUMAN-AGENT DIALOGUE
# Everything that flows between humans and agents
# ═══════════════════════════════════════════════════════════════════

ff:DialogueArtifact a owl:Class ;
    rdfs:label "Dialogue Artifact" ;
    rdfs:comment "Any artifact mediating human-agent interaction." .

ff:ConsultationRequestPack a owl:Class ;
    rdfs:subClassOf ff:DialogueArtifact ;
    rdfs:label "CRP — Consultation Request Pack" ;
    rdfs:comment """Agent-generated escalation to human. Contains: question, questionType
    (ambiguity/tradeoff/authority/conflict), context, options, routing.
    MUST be emitted when agent confidence < threshold.""" .

ff:CRPType a owl:Class ;
    owl:oneOf ( ff:AmbiguityCRP ff:TradeoffCRP ff:AuthorityCRP ff:ConflictCRP ) .

ff:CRPStatus a owl:Class ;
    owl:oneOf ( ff:CRPPending ff:CRPResolved ff:CRPExpired ) .

ff:VersionControlledResolution a owl:Class ;
    rdfs:subClassOf ff:DialogueArtifact ;
    rdfs:label "VCR — Version Controlled Resolution" ;
    rdfs:comment "Human's typed, traceable response to a CRP or MRP. The act of deciding IS the documentation." .

ff:MergeReadinessPack a owl:Class ;
    rdfs:subClassOf ff:DialogueArtifact ;
    rdfs:label "MRP — Merge Readiness Pack" ;
    rdfs:comment """Evidence bundle proving 5 SASE criteria: functional completeness, sound verification,
    SE hygiene, clear rationale, full auditability. Human approves merge based on evidence, not raw diffs.""" .

ff:MRPVerdict a owl:Class ;
    owl:oneOf ( ff:MergeReady ff:NeedsRevision ff:Rejected ) .

ff:ArchitectApproval a owl:Class ;
    rdfs:subClassOf ff:DialogueArtifact ;
    rdfs:comment "Human gate — approves/rejects a Function Proposal before compilation." .

ff:GateOverride a owl:Class ;
    rdfs:subClassOf ff:DialogueArtifact ;
    rdfs:comment "Human override of a failed gate — must carry explicit rationale in a VCR." .

ff:FeedbackCorrection a owl:Class ;
    rdfs:subClassOf ff:DialogueArtifact ;
    rdfs:comment "Human correction of agent behavior — captured as a MentorScript rule proposal." .


# ═══════════════════════════════════════════════════════════════════
# DOMAIN 6: AGENT TOPOLOGY
# Every agent role, its identity, capabilities, tools, permissions
# ═══════════════════════════════════════════════════════════════════

ff:AgentRole a owl:Class ;
    rdfs:label "Agent Role" ;
    rdfs:comment """A specialized role in the Factory swarm. Each role is a REAL agent
    (multi-turn loop with tools), NOT a prompt wrapper. If it can't read files,
    query databases, and reason across turns, it is not an agent.""" .

ff:ArchitectRole a ff:AgentRole ;
    rdfs:label "Architect Agent" ;
    rdfs:comment "Produces BriefingScripts with full codebase context. Replaces Stages 2-4." .

ff:PlannerRole a ff:AgentRole ;
    rdfs:label "Planner Agent" ;
    rdfs:comment "Decomposes WorkGraph into implementation plan." .

ff:CoderRole a ff:AgentRole ;
    rdfs:label "Coder Agent" ;
    rdfs:comment "Implements code against a plan. Requires filesystem, git, test runner." .

ff:CriticRole a ff:AgentRole ;
    rdfs:label "Critic Agent" ;
    rdfs:comment "Reviews PRDs for semantic alignment and code for quality." .

ff:TesterRole a ff:AgentRole ;
    rdfs:label "Tester Agent" ;
    rdfs:comment "Executes real tests. Requires filesystem and test runner." .

ff:VerifierRole a ff:AgentRole ;
    rdfs:label "Verifier Agent" ;
    rdfs:comment "Makes final pass/patch/resample/interrupt/fail decision." .

ff:Tool a owl:Class ;
    rdfs:label "Agent Tool" ;
    rdfs:comment "A capability available to an agent during a session." .

ff:FileReadTool a ff:Tool . ff:FileWriteTool a ff:Tool .
ff:BashExecuteTool a ff:Tool . ff:GrepSearchTool a ff:Tool .
ff:ArangoQueryTool a ff:Tool . ff:GitTool a ff:Tool .

ff:Permission a owl:Class ;
    owl:oneOf ( ff:CanRead ff:CanWrite ff:CanExecute ff:CanQuery ff:ReadOnly ) .

ff:MemoryAccess a owl:Class ;
    rdfs:comment "What institutional memory an agent loads at session start." .

ff:DecisionsMemory a ff:MemoryAccess .
ff:LessonsMemory a ff:MemoryAccess .
ff:MentorRulesMemory a ff:MemoryAccess .
ff:EpisodicMemory a ff:MemoryAccess .
ff:CodebaseAccess a ff:MemoryAccess .

ff:ExecutionEnvironment a owl:Class ;
    rdfs:comment "Where the agent runs." .

ff:V8Isolate a ff:ExecutionEnvironment ;
    rdfs:comment "Cloudflare Worker/Agent — no filesystem, no shell." .

ff:SandboxContainer a ff:ExecutionEnvironment ;
    rdfs:comment "CF Sandbox — real filesystem, git, pnpm, shell." .


# ═══════════════════════════════════════════════════════════════════
# DOMAIN 7: INFRASTRUCTURE & LIFECYCLE
# The deployment substrate and Function lifecycle states
# ═══════════════════════════════════════════════════════════════════

ff:InfrastructureComponent a owl:Class ;
    rdfs:label "Infrastructure Component" ;
    rdfs:comment "A deployed component of the Factory." .

ff:Worker a ff:InfrastructureComponent .
ff:Workflow a ff:InfrastructureComponent .
ff:DurableObject a ff:InfrastructureComponent .
ff:Container a ff:InfrastructureComponent .
ff:Queue a ff:InfrastructureComponent .
ff:R2Bucket a ff:InfrastructureComponent .
ff:ArangoCollection a ff:InfrastructureComponent .
ff:ArangoGraph a ff:InfrastructureComponent .

ff:FunctionLifecycleState a owl:Class ;
    owl:oneOf ( ff:Proposed ff:Designed ff:InProgress ff:Implemented
                ff:Verified ff:Monitored ff:Retired ) .

ff:FactoryMode a owl:Class ;
    owl:oneOf ( ff:Bootstrap ff:SteadyState ) .

ff:PipelineStage a owl:Class ;
    rdfs:comment "A stage in the Factory pipeline." .

ff:Stage1_Ingest a ff:PipelineStage . ff:Stage2_Pressure a ff:PipelineStage .
ff:Stage3_Capability a ff:PipelineStage . ff:Stage4_Proposal a ff:PipelineStage .
ff:Stage5_Compile a ff:PipelineStage . ff:Stage6_Synthesis a ff:PipelineStage .
ff:Stage7_Observe a ff:PipelineStage . ff:Stage8_PR a ff:PipelineStage .


# ═══════════════════════════════════════════════════════════════════
# SASE ENGINEERING ACTIVITIES
# Process types from the SASE framework
# ═══════════════════════════════════════════════════════════════════

sase:EngineeringActivity a owl:Class ;
    rdfs:label "SASE Engineering Activity" ;
    rdfs:comment "A structured engineering activity from the SASE framework." .

sase:BriefingEngineering a sase:EngineeringActivity ;
    rdfs:label "BriefingEng — The Art of the Mission Briefing" ;
    rdfs:comment "Human writes BriefingScript. Agent receives comprehensive brief, not a raw ticket." .

sase:LoopEngineering a sase:EngineeringActivity ;
    rdfs:label "LoopEng — Disciplined Orchestration" ;
    rdfs:comment "Defines agent workflow via LoopScript — task decomposition, workflow strategy, acceptance criteria." .

sase:MentorshipEngineering a sase:EngineeringActivity ;
    rdfs:label "MentorEng — Codifying Team Norms" ;
    rdfs:comment "Transforms implicit mentorship into explicit, evolving, codified discipline via MentorScript." .

sase:GuidanceEngineering a sase:EngineeringActivity ;
    rdfs:label "GuidanceEng — Leveraging the Human in the Loop" ;
    rdfs:comment "Formalizes human participation via CRP/VCR/MRP. Human intervenes at decision gates, not data gates." .

sase:InfrastructureEngineering a sase:EngineeringActivity ;
    rdfs:label "InfraEng — Building SE for Agents" ;
    rdfs:comment "Engineers the agent execution environment — persistent memory, agent-first code practices, native toolchain." .


# ═══════════════════════════════════════════════════════════════════
# OBJECT PROPERTIES — Relationships between things
# ═══════════════════════════════════════════════════════════════════

# ── Lineage ──
ff:derivesFrom a owl:ObjectProperty ;
    rdfs:domain ff:SpecificationArtifact ;
    rdfs:range ff:SpecificationArtifact ;
    rdfs:comment "Upstream derivation. Every non-Signal artifact MUST have at least one." .

ff:derivedFromSignal a owl:ObjectProperty ;
    rdfs:subPropertyOf ff:derivesFrom ;
    rdfs:domain ff:Pressure ;
    rdfs:range ff:Signal .

ff:compiledFrom a owl:ObjectProperty ;
    rdfs:subPropertyOf ff:derivesFrom ;
    rdfs:domain ff:WorkGraph ;
    rdfs:range ff:FunctionProposal .

ff:synthesizedFrom a owl:ObjectProperty ;
    rdfs:domain ff:ExecutionArtifact ;
    rdfs:range ff:WorkGraph .

# ── Production ──
ff:producedBy a owl:ObjectProperty ;
    rdfs:domain ff:ExecutionArtifact ;
    rdfs:range ff:AgentRole ;
    rdfs:comment "Which agent role produced this artifact." .

ff:producedAt a owl:ObjectProperty ;
    rdfs:domain ff:ExecutionArtifact ;
    rdfs:range ff:PipelineStage .

# ── Validation ──
ff:validatedBy a owl:ObjectProperty ;
    rdfs:domain ff:SpecificationArtifact ;
    rdfs:range ff:Gate .

ff:reviewedBy a owl:ObjectProperty ;
    rdfs:domain [ owl:unionOf ( ff:WorkGraph ff:CodeArtifact ff:PRDDraft ) ] ;
    rdfs:range ff:AgentRole ;
    rdfs:comment "EVERY WorkGraph, CodeArtifact, and PRDDraft MUST be reviewed." .

ff:gateResult a owl:ObjectProperty ;
    rdfs:domain ff:Gate ;
    rdfs:range ff:CoverageReport .

# ── Governance ──
ff:constrainedBy a owl:ObjectProperty ;
    rdfs:domain ff:AgentRole ;
    rdfs:range ff:MentorScript ;
    rdfs:comment "MentorScript rules that constrain this agent's behavior." .

ff:escalatesVia a owl:ObjectProperty ;
    rdfs:domain ff:AgentRole ;
    rdfs:range ff:ConsultationRequestPack ;
    rdfs:comment "When uncertain, agents MUST escalate via CRP." .

ff:resolvedBy a owl:ObjectProperty ;
    rdfs:domain ff:ConsultationRequestPack ;
    rdfs:range ff:VersionControlledResolution .

ff:approvedBy a owl:ObjectProperty ;
    rdfs:domain ff:MergeReadinessPack ;
    rdfs:range ff:VersionControlledResolution .

# ── Missing properties (SE review amendment) ──
ff:relatedArtifact a owl:ObjectProperty ;
    rdfs:domain ff:ConsultationRequestPack ;
    rdfs:range owl:Thing ;
    rdfs:comment "The artifact that triggered this CRP (used in C7 confidence escalation)." .

ff:groundedIn a owl:ObjectProperty ;
    rdfs:domain ff:CritiqueReport ;
    rdfs:range ff:Signal ;
    rdfs:comment "The originating Signal whose specContent grounds this review (C10)." .

ff:communicatesVia a owl:ObjectProperty ;
    rdfs:domain ff:Workflow ;
    rdfs:range ff:Queue ;
    rdfs:comment "Workflows MUST communicate with DOs via Queue, not direct RPC (C16)." .

ff:goal a owl:DatatypeProperty ;
    rdfs:domain ff:BriefingScript ;
    rdfs:range xsd:string .

ff:successCriteria a owl:DatatypeProperty ;
    rdfs:domain ff:BriefingScript ;
    rdfs:range xsd:string .

ff:architecturalContext a owl:DatatypeProperty ;
    rdfs:domain ff:BriefingScript ;
    rdfs:range xsd:string .

ff:strategicAdvice a owl:DatatypeProperty ;
    rdfs:domain ff:BriefingScript ;
    rdfs:range xsd:string .

ff:knownGotchas a owl:DatatypeProperty ;
    rdfs:domain ff:BriefingScript ;
    rdfs:range xsd:string .

ff:validationLoop a owl:DatatypeProperty ;
    rdfs:domain ff:BriefingScript ;
    rdfs:range xsd:string .

ff:evidenceSources a owl:DatatypeProperty ;
    rdfs:domain ff:DetectorSpec ;
    rdfs:range xsd:string .

ff:directRules a owl:DatatypeProperty ;
    rdfs:domain ff:DetectorSpec ;
    rdfs:range xsd:string .

ff:regressionPolicy a owl:DatatypeProperty ;
    rdfs:domain ff:DetectorSpec ;
    rdfs:range xsd:string .

ff:mentorRulesChecked a owl:DatatypeProperty ;
    rdfs:domain ff:CritiqueReport ;
    rdfs:range xsd:string .

ff:content a owl:DatatypeProperty ;
    rdfs:domain ff:CodeArtifact ;
    rdfs:range xsd:string .

ff:reviewType a owl:DatatypeProperty ;
    rdfs:domain ff:CritiqueReport ;
    rdfs:range xsd:string .

# ── Lifecycle State Transitions (dynamics model) ──
ff:allowedTransition a owl:ObjectProperty ;
    rdfs:domain ff:FunctionLifecycleState ;
    rdfs:range ff:FunctionLifecycleState ;
    rdfs:comment "Allowed lifecycle state transitions. Transitions not in this graph are forbidden." .

ff:transitionRequires a owl:ObjectProperty ;
    rdfs:domain ff:FunctionLifecycleState ;
    rdfs:range ff:Gate ;
    rdfs:comment "Gate that must pass for this transition to be allowed." .

ff:Proposed ff:allowedTransition ff:Designed .
ff:Designed ff:allowedTransition ff:InProgress .
ff:InProgress ff:allowedTransition ff:Implemented .
ff:Implemented ff:allowedTransition ff:Verified ;
    ff:transitionRequires ff:Gate2 .
ff:Verified ff:allowedTransition ff:Monitored ;
    ff:transitionRequires ff:Gate3 .
ff:Monitored ff:allowedTransition ff:Retired .

# ── Agent Capabilities ──
ff:hasTools a owl:ObjectProperty ;
    rdfs:domain ff:AgentRole ;
    rdfs:range ff:Tool ;
    rdfs:comment "Tools available to this agent. An agent without tools is not an agent." .

ff:hasPermission a owl:ObjectProperty ;
    rdfs:domain ff:AgentRole ;
    rdfs:range ff:Permission .

ff:hasMemoryAccess a owl:ObjectProperty ;
    rdfs:domain ff:AgentRole ;
    rdfs:range ff:MemoryAccess .

ff:runsIn a owl:ObjectProperty ;
    rdfs:domain ff:AgentRole ;
    rdfs:range ff:ExecutionEnvironment .

ff:usesModel a owl:ObjectProperty ;
    rdfs:domain ff:AgentRole ;
    rdfs:range ff:ModelRoute .

# ── Infrastructure ──
ff:persistedIn a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range ff:ArangoCollection .

ff:triggeredBy a owl:ObjectProperty ;
    rdfs:domain ff:PipelineStage ;
    rdfs:range ff:PipelineStage .

# ── Lifecycle ──
ff:hasLifecycleState a owl:ObjectProperty ;
    rdfs:domain ff:FunctionProposal ;
    rdfs:range ff:FunctionLifecycleState .

ff:detectedBy a owl:ObjectProperty ;
    rdfs:domain ff:Invariant ;
    rdfs:range ff:DetectorSpec ;
    rdfs:comment "An Invariant without a Detector is a wish. Gate 1 rejects." .


# ═══════════════════════════════════════════════════════════════════
# DATA PROPERTIES — Typed attributes
# ═══════════════════════════════════════════════════════════════════

ff:artifactId a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Factory artifact ID matching pattern: PREFIX-QUALIFIER-NAME" .

ff:specContent a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "The verbatim specification text. Must propagate through entire derivation chain without loss." .

ff:sourceRefs a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Array of upstream artifact IDs. Empty only for Stage 1 Signals." .

ff:explicitness a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Whether this field is explicit (stated) or inferred (derived). Values: explicit, inferred." .

ff:rationale a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Explanation for inferred values or decisions." .

ff:confidence a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:decimal ;
    rdfs:comment "0.0-1.0 confidence score. Below threshold MUST trigger CRP." .

ff:derivationMode a owl:DatatypeProperty ;
    rdfs:domain ff:SpecificationArtifact ;
    rdfs:range xsd:string ;
    rdfs:comment "How this artifact was derived: extracted, generated, pre-authored, architect-extracted." .

ff:timestamp a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:dateTime .

ff:tokenUsage a owl:DatatypeProperty ;
    rdfs:domain ff:ExecutionArtifact ;
    rdfs:range xsd:integer .

ff:repairCount a owl:DatatypeProperty ;
    rdfs:domain ff:SynthesisSession ;
    rdfs:range xsd:integer .

ff:passed a owl:DatatypeProperty ;
    rdfs:domain [ owl:unionOf ( ff:CoverageReport ff:CritiqueReport ff:TestReport ) ] ;
    rdfs:range xsd:boolean .


# ═══════════════════════════════════════════════════════════════════
# MODEL ROUTING
# ═══════════════════════════════════════════════════════════════════

ff:ModelRoute a owl:Class ;
    rdfs:comment "A provider/model pair for LLM routing." .

ff:Provider a owl:Class ;
    owl:oneOf ( ff:DeepSeek ff:Google ff:Anthropic ff:ZAI
                ff:MoonshotAI ff:MiniMax ff:OpenAI ff:Cloudflare ) .

ff:TaskKind a owl:Class ;
    owl:oneOf ( ff:PlanningTask ff:StructuredTask ff:InterpretiveTask
                ff:CriticTask ff:SynthesisTask ff:ValidationTask
                ff:RuntimeCheckTask ff:SemanticReviewTask
                ff:PlannerTask ff:CoderTask ff:TesterTask ff:VerifierTask ) .


# ═══════════════════════════════════════════════════════════════════
# ROLE CONSTRAINTS — What each agent CAN and CANNOT do
# ═══════════════════════════════════════════════════════════════════

ff:ArchitectRole ff:hasTools ff:FileReadTool, ff:GrepSearchTool, ff:ArangoQueryTool ;
    ff:hasPermission ff:ReadOnly ;
    ff:hasMemoryAccess ff:DecisionsMemory, ff:LessonsMemory, ff:MentorRulesMemory, ff:CodebaseAccess ;
    ff:runsIn ff:V8Isolate .

ff:PlannerRole ff:hasTools ff:FileReadTool, ff:GrepSearchTool ;
    ff:hasPermission ff:ReadOnly ;
    ff:hasMemoryAccess ff:DecisionsMemory, ff:LessonsMemory ;
    ff:runsIn ff:V8Isolate .

ff:CoderRole ff:hasTools ff:FileReadTool, ff:FileWriteTool, ff:BashExecuteTool, ff:GrepSearchTool, ff:GitTool ;
    ff:hasPermission ff:CanRead, ff:CanWrite, ff:CanExecute ;
    ff:hasMemoryAccess ff:DecisionsMemory, ff:LessonsMemory, ff:MentorRulesMemory, ff:CodebaseAccess ;
    ff:runsIn ff:SandboxContainer .

ff:CriticRole ff:hasTools ff:FileReadTool, ff:GrepSearchTool, ff:ArangoQueryTool ;
    ff:hasPermission ff:ReadOnly ;
    ff:hasMemoryAccess ff:DecisionsMemory, ff:LessonsMemory, ff:MentorRulesMemory, ff:CodebaseAccess ;
    ff:runsIn ff:V8Isolate .

ff:TesterRole ff:hasTools ff:FileReadTool, ff:BashExecuteTool, ff:GrepSearchTool ;
    ff:hasPermission ff:CanRead, ff:CanExecute ;
    ff:hasMemoryAccess ff:LessonsMemory, ff:MentorRulesMemory ;
    ff:runsIn ff:SandboxContainer .

ff:VerifierRole ff:hasTools ff:FileReadTool, ff:GrepSearchTool, ff:ArangoQueryTool ;
    ff:hasPermission ff:ReadOnly ;
    ff:hasMemoryAccess ff:DecisionsMemory, ff:LessonsMemory ;
    ff:runsIn ff:V8Isolate .


# ═══════════════════════════════════════════════════════════════════
# INFRASTRUCTURE INSTANCES
# ═══════════════════════════════════════════════════════════════════

ff:ffGateway a ff:Worker ; rdfs:label "ff-gateway" .
ff:ffPipeline a ff:Worker ; rdfs:label "ff-pipeline" .
ff:ffGates a ff:Worker ; rdfs:label "ff-gates" .
ff:factoryPipeline a ff:Workflow ; rdfs:label "factory-pipeline" .
ff:synthesisCoordinator a ff:DurableObject ; rdfs:label "SynthesisCoordinator" .
ff:sandbox a ff:Container ; rdfs:label "Sandbox" .
ff:synthesisQueue a ff:Queue ; rdfs:label "synthesis-queue" .
ff:ffWorkspaces a ff:R2Bucket ; rdfs:label "ff-workspaces" .

# ArangoDB Collections
ff:col_signals a ff:ArangoCollection ; rdfs:label "specs_signals" .
ff:col_pressures a ff:ArangoCollection ; rdfs:label "specs_pressures" .
ff:col_capabilities a ff:ArangoCollection ; rdfs:label "specs_capabilities" .
ff:col_functions a ff:ArangoCollection ; rdfs:label "specs_functions" .
ff:col_prds a ff:ArangoCollection ; rdfs:label "specs_prds" .
ff:col_workgraphs a ff:ArangoCollection ; rdfs:label "specs_workgraphs" .
ff:col_invariants a ff:ArangoCollection ; rdfs:label "specs_invariants" .
ff:col_coverage_reports a ff:ArangoCollection ; rdfs:label "specs_coverage_reports" .
ff:col_execution_artifacts a ff:ArangoCollection ; rdfs:label "execution_artifacts" .
ff:col_mentorscript_rules a ff:ArangoCollection ; rdfs:label "mentorscript_rules" .
ff:col_consultation_requests a ff:ArangoCollection ; rdfs:label "consultation_requests" .
ff:col_vcrs a ff:ArangoCollection ; rdfs:label "version_controlled_resolutions" .
ff:col_mrps a ff:ArangoCollection ; rdfs:label "merge_readiness_packs" .
ff:col_gate_status a ff:ArangoCollection ; rdfs:label "gate_status" .
ff:col_trust_scores a ff:ArangoCollection ; rdfs:label "trust_scores" .
ff:col_memory_episodic a ff:ArangoCollection ; rdfs:label "memory_episodic" .
ff:col_memory_semantic a ff:ArangoCollection ; rdfs:label "memory_semantic" .
ff:col_memory_working a ff:ArangoCollection ; rdfs:label "memory_working" .
ff:col_memory_personal a ff:ArangoCollection ; rdfs:label "memory_personal" .
ff:col_function_runs a ff:ArangoCollection ; rdfs:label "function_runs" .

# ArangoDB Graphs
ff:lineageGraph a ff:ArangoGraph ; rdfs:label "lineage_graph" .
ff:assuranceGraph a ff:ArangoGraph ; rdfs:label "assurance_graph" .
ff:dependencyGraph a ff:ArangoGraph ; rdfs:label "dependency_graph" .


# ═══════════════════════════════════════════════════════════════════
# PERSISTENCE MAPPINGS — What lives where
# ═══════════════════════════════════════════════════════════════════

ff:Signal ff:persistedIn ff:col_signals .
ff:Pressure ff:persistedIn ff:col_pressures .
ff:BusinessCapability ff:persistedIn ff:col_capabilities .
ff:FunctionProposal ff:persistedIn ff:col_functions .
ff:PRDDraft ff:persistedIn ff:col_prds .
ff:WorkGraph ff:persistedIn ff:col_workgraphs .
ff:Invariant ff:persistedIn ff:col_invariants .
ff:CoverageReport ff:persistedIn ff:col_coverage_reports .
ff:MentorScript ff:persistedIn ff:col_mentorscript_rules .
ff:ConsultationRequestPack ff:persistedIn ff:col_consultation_requests .
ff:VersionControlledResolution ff:persistedIn ff:col_vcrs .
ff:MergeReadinessPack ff:persistedIn ff:col_mrps .
ff:BriefingScript ff:persistedIn ff:col_execution_artifacts .
ff:Plan ff:persistedIn ff:col_execution_artifacts .
ff:CodeArtifact ff:persistedIn ff:col_execution_artifacts .
ff:CritiqueReport ff:persistedIn ff:col_execution_artifacts .
ff:TestReport ff:persistedIn ff:col_execution_artifacts .
ff:Verdict ff:persistedIn ff:col_execution_artifacts .
ff:SynthesisSession ff:persistedIn ff:col_execution_artifacts .
ff:Trajectory ff:persistedIn ff:col_memory_episodic .
ff:TrustComposite ff:persistedIn ff:col_trust_scores .
